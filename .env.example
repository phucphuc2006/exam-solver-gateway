# Exam Solver AI Gateway - Environment Configuration

# Required
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=./data

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=exam-solver-gateway-secret
MACHINE_ID_SALT=exam-solver-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false

# Base URL
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# Optional outbound proxy variables for upstream provider calls
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
